PRODUCTV2_DATABASE_PATH=data/productv2.db
PRODUCTV2_RAW_DATA_DIR=data/raw
PRODUCTV2_PRODUCT_ASSETS_DIR=data/products
PRODUCTV2_WORKFLOW_LOGS_DIR=workflow-logs
PRODUCTV2_DEFAULT_LIMIT=5
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-5.5
OPENAI_API_BASE=https://www.lynxhub.top
OPENAI_USE_RESPONSES_API=true
OPENAI_STREAMING=true
OPENAI_OUTPUT_VERSION=responses/v1
OPENAI_STREAM_USAGE=false
OPENAI_TIMEOUT=120
OPENAI_MAX_RETRIES=2
OPENAI_FALLBACK_PROVIDERS=[{"name":"backup","api_base":"https://backup.example.com","api_key":"sk-your-fallback-key"}]
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_your-langsmith-key
LANGSMITH_PROJECT=productv2
ENROUTE_ANALYSIS_TEMPERATURE=0.9
ENROUTE_ANALYSIS_TOP_P=0.9
IMAGE_GENERATION_API_KEY=sk-your-image-generation-key
IMAGE_GENERATION_API_BASE=https://grsaiapi.com
IMAGE_GENERATION_MODEL=gpt-image-2
IMAGE_GENERATION_ASPECT_RATIO=4/5
IMAGE_GENERATION_REPLY_TYPE=async
IMAGE_GENERATION_TIMEOUT=600
IMAGE_GENERATION_MAX_RETRIES=2
IMAGE_GENERATION_POLL_INTERVAL=2
IMAGE_GENERATION_POLL_TIMEOUT=600
AI_CALL_LOCK_WAIT_TIMEOUT=900
AI_CALL_LOCK_POLL_INTERVAL=2
AI_CALL_LOCK_STALE_AFTER=3600
FEISHU_APP_ID=cli-your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
